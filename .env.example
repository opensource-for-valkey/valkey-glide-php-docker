# Copy to .env and adjust for your environment: cp .env.example .env
# Consumed by docker-compose.yml.

# --- MariaDB ----------------------------------------------------------
MARIADB_ROOT_PASSWORD=valkeyglide_secret
MARIADB_DATABASE=valkeyglide
MARIADB_USER=valkeyglide
MARIADB_PASSWORD=valkeyglide_secret

# --- PostgreSQL -------------------------------------------------------
POSTGRES_DB=valkeyglide
POSTGRES_USER=valkeyglide
POSTGRES_PASSWORD=valkeyglide_secret

# --- SQLite -----------------------------------------------------------
# File-based (no server). Path inside the PHP container.
SQLITE_DATABASE=/var/www/sqlite/valkeyglide.sqlite
