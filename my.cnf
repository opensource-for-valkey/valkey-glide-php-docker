# MariaDB configuration — mounted at /etc/mysql/conf.d/my.cnf
# Sensible defaults for local development with valkey-glide-php.

[client]
default-character-set = utf8mb4

[mysqld]
# --- Character set & collation (full UTF-8) ---------------------------
character-set-server  = utf8mb4
collation-server      = utf8mb4_unicode_ci

# --- Networking -------------------------------------------------------
bind-address     = 0.0.0.0
skip-name-resolve                 # skip reverse DNS on connect (faster, no DNS deps)
max_connections  = 100

# --- InnoDB -----------------------------------------------------------
default_storage_engine       = InnoDB
innodb_buffer_pool_size      = 256M
innodb_log_file_size         = 64M
innodb_flush_log_at_trx_commit = 1   # ACID-safe; set 2 for faster, less durable dev
innodb_flush_method          = O_DIRECT
innodb_file_per_table        = 1

# --- Safety & correctness --------------------------------------------
sql_mode = STRICT_TRANS_TABLES,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION

# --- Logging ----------------------------------------------------------
slow_query_log       = 1
slow_query_log_file  = /var/lib/mysql/slow.log
long_query_time      = 2

[mysqldump]
quick
quote-names
max_allowed_packet = 64M
